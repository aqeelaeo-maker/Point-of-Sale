{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "The user's username"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The user's role"
        }
      },
      "required": ["username", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "A product in the inventory",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the product"
        },
        "barcode": {
          "type": "string",
          "description": "The barcode of the product"
        },
        "unit": {
          "type": "string",
          "description": "The unit of measurement"
        },
        "cost_price": {
          "type": "number",
          "description": "The cost price of the product"
        },
        "price_per_unit": {
          "type": "number",
          "description": "The selling price of the product"
        },
        "stock": {
          "type": "number",
          "description": "The current stock level"
        },
        "batch_number": {
          "type": "string",
          "description": "The batch number"
        },
        "expiry_date": {
          "type": "string",
          "description": "The expiry date"
        }
      },
      "required": ["name", "unit", "cost_price", "price_per_unit", "stock"]
    },
    "Customer": {
      "title": "Customer",
      "description": "A customer of the store",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the customer"
        },
        "phone": {
          "type": "string",
          "description": "The phone number of the customer"
        },
        "loan_balance": {
          "type": "number",
          "description": "The current loan balance of the customer"
        }
      },
      "required": ["name", "loan_balance"]
    },
    "Vendor": {
      "title": "Vendor",
      "description": "A vendor of the store",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the vendor"
        },
        "phone": {
          "type": "string",
          "description": "The phone number of the vendor"
        },
        "balance": {
          "type": "number",
          "description": "The current balance of the vendor"
        }
      },
      "required": ["name", "balance"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A sale transaction",
      "type": "object",
      "properties": {
        "customer_id": {
          "type": "string",
          "description": "The ID of the customer"
        },
        "total_amount": {
          "type": "number",
          "description": "The total amount of the sale"
        },
        "paid_amount": {
          "type": "number",
          "description": "The amount paid by the customer"
        },
        "date": {
          "type": "string",
          "description": "The date of the sale"
        }
      },
      "required": ["total_amount", "paid_amount", "date"]
    },
    "SaleItem": {
      "title": "SaleItem",
      "description": "An item in a sale transaction",
      "type": "object",
      "properties": {
        "product_id": {
          "type": "string",
          "description": "The ID of the product"
        },
        "quantity": {
          "type": "number",
          "description": "The quantity sold"
        },
        "cost_price": {
          "type": "number",
          "description": "The cost price of the product"
        },
        "unit_price": {
          "type": "number",
          "description": "The selling price of the product"
        },
        "total_price": {
          "type": "number",
          "description": "The total price of the item"
        }
      },
      "required": ["product_id", "quantity", "cost_price", "unit_price", "total_price"]
    },
    "Setting": {
      "title": "Setting",
      "description": "A store setting",
      "type": "object",
      "properties": {
        "value": {
          "type": "string",
          "description": "The value of the setting"
        }
      },
      "required": ["value"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Products in the inventory"
    },
    "customers/{customerId}": {
      "schema": { "$ref": "#/entities/Customer" },
      "description": "Customers of the store"
    },
    "vendors/{vendorId}": {
      "schema": { "$ref": "#/entities/Vendor" },
      "description": "Vendors of the store"
    },
    "sales/{saleId}": {
      "schema": { "$ref": "#/entities/Sale" },
      "description": "Sale transactions"
    },
    "sales/{saleId}/items/{itemId}": {
      "schema": { "$ref": "#/entities/SaleItem" },
      "description": "Items in a sale transaction"
    },
    "settings/{settingId}": {
      "schema": { "$ref": "#/entities/Setting" },
      "description": "Store settings"
    }
  }
}
